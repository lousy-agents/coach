{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/setup-mise.sh"
            ],
            "timeout": 300,
            "statusMessage": "Preparing mise toolchain"
          }
        ]
      }
    ]
  }
}
