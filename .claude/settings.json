{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/setup-mise.sh"
            ],
            "timeout": 300,
            "statusMessage": "Preparing mise toolchain"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "task-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/verify-review-verdict.sh"
            ]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(gh pr create*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/gate-pr-creation.sh"
            ]
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/verify-context-relay.sh"
            ]
          }
        ]
      }
    ]
  }
}
