{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "helpers:pinGitHubActionDigestsToSemver",
        "security:openssf-scorecard"
    ],
    "automerge": true,
    "platformAutomerge": true,
    "lockFileMaintenance": {
        "enabled": true,
        "automergeType": "branch"
    },
    "semanticCommitType": "fix",
    "semanticCommitScope": "deps",
    "pinDigests": true,
    "dependencyDashboard": true,
    "postUpdateOptions": [
        "gomodTidy",
        "gomodUpdateImportPaths"
    ],
    "packageRules": [
        {
            "description": "Disable native mise manager due to untrusted config errors",
            "matchManagers": ["mise"],
            "enabled": false
        },
        {
            "description": "Pin all npm dependencies to exact versions",
            "matchManagers": ["npm"],
            "rangeStrategy": "pin"
        },
        {
            "description": "Group Onsi test packages",
            "matchManagers": ["gomod"],
            "matchPackageNames": [
                "github.com/onsi/ginkgo/v2",
                "github.com/onsi/gomega"
            ],
            "groupName": "onsi-test"
        },
        {
            "description": "Group golang.org/x modules",
            "matchManagers": ["gomod"],
            "groupName": "golang-x",
            "matchPackageNames": [
                "/^golang\\.org/x//"
            ]
        }
    ],
    "customManagers": [
        {
            "description": "Track Go version in mise.toml and the Claude cloud setup script (parity-tested together)",
            "customType": "regex",
            "managerFilePatterns": [
                "/(^|/)mise\\.toml$/",
                "/(^|/)\\.claude/cloud-env-setup\\.sh$/"
            ],
            "matchStrings": [
                "(?:^|\\n)go\\s*=\\s*\"(?<currentValue>[^\"]+)\"",
                "go_version=\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "golang/go",
            "datasourceTemplate": "github-tags",
            "extractVersionTemplate": "^go(?<version>.*)$"
        },
        {
            "description": "Track Node.js version in mise.toml and the Claude cloud setup script (parity-tested together)",
            "customType": "regex",
            "managerFilePatterns": [
                "/(^|/)mise\\.toml$/",
                "/(^|/)\\.claude/cloud-env-setup\\.sh$/"
            ],
            "matchStrings": [
                "(?:^|\\n)node\\s*=\\s*\"(?<currentValue>[^\"]+)\"",
                "node_version=\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "nodejs/node",
            "datasourceTemplate": "github-tags",
            "versioningTemplate": "node"
        },
        {
            "description": "Track mise minimum version in mise.toml and the Claude cloud setup script (parity-tested together)",
            "customType": "regex",
            "managerFilePatterns": [
                "/(^|/)mise\\.toml$/",
                "/(^|/)\\.claude/cloud-env-setup\\.sh$/"
            ],
            "matchStrings": [
                "min_version\\s*=\\s*\"(?<currentValue>[^\"]+)\"",
                "mise_version=\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "jdx/mise",
            "datasourceTemplate": "github-releases"
        }
    ]
}
